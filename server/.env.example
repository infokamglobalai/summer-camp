# ============================================================
# AI Adventure Camp — Backend .env.example
# Copy this file to .env and fill in your actual values
# NEVER commit your actual .env file to Git
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # change to "production" when deploying
FRONTEND_URL=http://localhost:5173   # React dev server URL

# ── MongoDB ─────────────────────────────────────────────────
# Get this from: MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai-summer-camp?retryWrites=true&w=majority

# ── JWT (Admin Authentication) ──────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_key_here
JWT_EXPIRES_IN=7d

# ── Admin Credentials (stored in DB on first run) ───────────
ADMIN_EMAIL=admin@eduaitutors.com
ADMIN_PASSWORD=YourStrongAdminPassword123!

# ── Ottu Payment Gateway ────────────────────────────────────
# Get these from: Ottu Dashboard → Developers → API Keys
OTTU_BASE_URL=https://YOUR_STORE.ottu.net       # e.g. https://eduaitutors.ottu.net
OTTU_API_KEY=your_ottu_api_key_here
OTTU_PLUGIN=MERCHANT_PLUGIN                      # your plugin code from Ottu dashboard

# These are the redirect URLs Ottu sends user to after payment
PAYMENT_SUCCESS_URL=http://localhost:5173/payment-success
PAYMENT_CANCEL_URL=http://localhost:5173/payment-cancel
PAYMENT_ERROR_URL=http://localhost:5173/payment-error

# Ottu Webhook secret (for verifying webhook signatures)
OTTU_WEBHOOK_SECRET=your_ottu_webhook_secret_here

# ── SMTP (Email) ─────────────────────────────────────────────
# Works with Gmail, Outlook, Zoho, custom SMTP etc.

# --- Gmail Example ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false                     # true for port 465, false for 587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password     # Gmail → Security → App Passwords

# --- Outlook / Hotmail Example ---
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@outlook.com
# SMTP_PASS=your_password

# --- Zoho Mail Example ---
# SMTP_HOST=smtp.zoho.in
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@zohomail.com
# SMTP_PASS=your_password

# --- Custom SMTP (cPanel / Hostinger) ---
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=your_password

# FROM display name and address for sent emails
SMTP_FROM_NAME=EduAiTutors Camp
SMTP_FROM_EMAIL=noreply@eduaitutors.com

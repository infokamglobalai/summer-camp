PORT=5000
MONGODB_URI=your_mongodb_connection_string

# Ottu Payment Configuration
OTTU_API_KEY=your_ottu_api_key
OTTU_API_URL=https://pay.eduaitutors.com/b/checkout/v1/pymt-txn/
OTTU_PG_CODE=payu

# Production URLs (Required for Live)
FRONTEND_URL=https://your-frontend-domain.com
BACKEND_URL=https://your-backend-api.com
WEBHOOK_URL=https://your-backend-api.com/api/payment/ottu/webhook
REDIRECT_URL=https://your-frontend-domain.com/payment-success

# SMTP Email Configuration
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@eduaitutors.com
SMTP_PASS=your-app-password
SMTP_SECURE=tls

# Admin: list enrollments (GET /api/admin/enrollments). Set a long random secret.
ADMIN_API_KEY=your_long_random_admin_secret
